generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String
  name                 String
  role                 Role
  mustChangePassword   Boolean  @default(false)
  createdAt            DateTime @default(now())
  tasksCreated         Task[]   @relation("TaskCreator")
  tasksAssigned        Task[]   @relation("TaskAssignee")
}

enum Role {
  AGENT
  MANAGER
  ADMIN
}

model Project {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#4f46e5")
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id        String   @id @default(cuid())
  title     String
  notes     String?
  priority  Int @default(5)
  dueAt     DateTime?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  creatorId String?
  creator   User?    @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  assignedToId String?
  assignee     User?   @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  reviewStatus    ReviewStatus    @default(PENDING_REVIEW)
  executionStatus ExecutionStatus @default(NOT_STARTED)
  managerNote     String?
  helpNote        String?
  isRedoRequest   Boolean         @default(false)
  redoRequestNote String?
}

enum ReviewStatus {
  PENDING_REVIEW
  APPROVED
  CHANGES_REQUESTED
  DENIED
}

enum ExecutionStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  NEEDS_HELP
}

